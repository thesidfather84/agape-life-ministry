# ------------------------------------------------------------------
# Agape Life Ministry — environment variables
# Copy this file to .env.local for local development, and add the
# same values in Netlify (Site configuration > Environment variables).
# ------------------------------------------------------------------

# The site's public URL. Change this if a different domain is used.
NEXT_PUBLIC_SITE_URL=https://agapelifeministry.org

# From your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Pastor email notifications (Resend) ---
# Server-side only; never exposed to the browser.
# Create the key at https://resend.com (API Keys).
RESEND_API_KEY=

# Where form notifications are delivered.
PASTOR_NOTIFICATION_EMAIL=arthurwarning49@gmail.com

# The "from" address. agapelifeministry.org must be verified inside
# Resend before this address works. Until then, leave this unset (or
# use onboarding@resend.dev) — the code falls back to Resend's
# approved testing sender automatically.
EMAIL_FROM_ADDRESS=website@agapelifeministry.org
